# =============================================================================
# WikiBridge — Configuración para desarrollo EN CASA (sin Wiki.js)
# Este archivo SÍ se commitea. Lo copian setup-windows-home.ps1 y start-home.sh
# NO uses este archivo en el trabajo — allí tienes tu .env de producción.
# =============================================================================

# --- PostgreSQL (local) ---
POSTGRES_USER=wikibridge
POSTGRES_PASSWORD=wikibridge
POSTGRES_DB=wikibridge
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wikibridge:wikibridge@localhost:5432/wikibridge

# --- Redis (local) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- API ---
API_PORT=8000
DEBUG=true

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
CHAT_MODEL=phi3:mini
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=700
OLLAMA_NUM_PREDICT_SHORT=400
OLLAMA_MAX_CONTINUE_ROUNDS=2
OLLAMA_NUM_THREAD=0
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MAX_CONCURRENCY=1

# --- Wiki.js deshabilitado en casa ---
WIKIJS_URL=
WIKIJS_API_KEY=
WIKIJS_SSL_VERIFY=false
WIKIJS_LOCALE=es

# Token interno web ↔ API (mismo valor en ambos)
INTERNAL_SERVICE_TOKEN=wikibridge-internal-dev-token

# --- Web / NextAuth ---
WEB_PORT=3000
INTERNAL_API_URL=http://localhost:8000
AUTH_SECRET=dev-secret-solo-para-casa
AUTH_MODE=local
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=admin
LOCAL_AUTH_ROLE=admin

# --- Worker ---
NIGHTLY_SYNC_CRON_HOUR=2
NIGHTLY_SYNC_CRON_MINUTE=0

# --- Salud documental ---
STALENESS_PROCEDURE_DAYS=180
STALENESS_REFERENCE_DAYS=365
INTERNAL_HOST_WHITELIST=*.ejemplo.interno,10.0.0.0/8
