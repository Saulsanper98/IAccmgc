# =============================================================================
# WikiBridge — Environment Configuration
# Copy to .env in the project root and adjust values for your environment.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=wikibridge
POSTGRES_PASSWORD=wikibridge
POSTGRES_DB=wikibridge
POSTGRES_PORT=5432
# Puerto en el host para DBeaver/pgAdmin (5432 suele estar ocupado en Windows)
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql+asyncpg://wikibridge:wikibridge@postgres:5432/wikibridge

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- API ---
API_PORT=8000
DEBUG=false

# --- Ollama (runs outside Docker, on dedicated VM) ---
# On Windows/Mac Docker Desktop use host.docker.internal
# On Linux use the host IP or extra_hosts in compose
OLLAMA_BASE_URL=http://host.docker.internal:11434
CHAT_MODEL=qwen2.5:3b-instruct
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=1500
OLLAMA_NUM_PREDICT_SHORT=700
OLLAMA_MAX_CONTINUE_ROUNDS=2
OLLAMA_NUM_THREAD=0
OLLAMA_KEEP_ALIVE=5m
# Mantener bge-m3 cargado entre consultas acelera el time-to-first-token (requiere más RAM).
OLLAMA_EMBEDDING_KEEP_ALIVE=2m
# true = descargar embeddings antes del chat (ahorra RAM, más lento).
OLLAMA_UNLOAD_EMBEDDING_BEFORE_CHAT=false
OLLAMA_EMBED_BATCH_SIZE=4
OLLAMA_MAX_CONCURRENCY=1

# RAG tuning
RAG_FINAL_CHUNKS=6
RAG_SUMMARY_FINAL_CHUNKS=10
RAG_CHUNK_MAX_CHARS=900
RAG_MAX_CHUNKS_PER_PAGE=2
RAG_CITATION_FALLBACK_MAX=2

# --- Wiki.js (Phase 1+) ---
WIKIJS_URL=https://wiki.ejemplo.interno
WIKIJS_API_KEY=
WIKIJS_SSL_VERIFY=false
WIKIJS_LOCALE=es

# Token interno web → API (no exponer al cliente)
INTERNAL_SERVICE_TOKEN=genera-otro-secreto-interno

# --- Web / NextAuth ---
WEB_PORT=3000
AUTH_SECRET=genera-un-secreto-largo-y-aleatorio-aqui
AUTH_MODE=local
# AUTH_MODE=ldap

# Local dev credentials (only when AUTH_MODE=local)
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=admin
LOCAL_AUTH_ROLE=admin

# LDAP (Phase 6 — placeholders)
LDAP_URL=ldap://ad.ejemplo.interno:389
LDAP_BASE_DN=DC=ejemplo,DC=local
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# --- Worker ---
# Horas UTC del contenedor worker (0–23), separadas por comas. Sync incremental en cada hora.
INCREMENTAL_SYNC_CRON_HOURS=2,8,14,20
INCREMENTAL_SYNC_CRON_MINUTE=0

QUERY_EMBEDDING_CACHE_TTL_SECONDS=300

# --- Validated Q&A learning circuit ---
VALIDATED_QA_RECALL_THRESHOLD=0.70
VALIDATED_QA_VERIFY_BYPASS=0.98
VALIDATED_QA_VERIFY_MODEL=qwen2.5:7b-instruct
VALIDATED_QA_VERIFY_TIMEOUT_SECONDS=30
VALIDATED_QA_MAX_RESULTS=2
# direct = respuesta almacenada sin LLM de chat (default) | inject = inyectar en system prompt
VALIDATED_QA_MODE=direct
# VALIDATED_QA_SIMILARITY_THRESHOLD=0.85

# --- Staleness detectors (Phase 3+) ---
STALENESS_PROCEDURE_DAYS=180
STALENESS_REFERENCE_DAYS=365
INTERNAL_HOST_WHITELIST=*.ejemplo.interno,10.0.0.0/8
